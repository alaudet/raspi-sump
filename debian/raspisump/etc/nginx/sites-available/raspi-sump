server {
    listen 80;
    server_name _;

    root /usr/share/raspi-sump/web;
    index index.html;

    # Serve the main site (static files, CSS, JS, images)
    location / {
        try_files $uri $uri/ =404;
    }

    # Serve charts from the raspisump state directory
    # today.png and year/month/ historical charts
    location /charts/ {
        alias /var/lib/raspi-sump/charts/;
        autoindex on;
        autoindex_exact_size off;
        autoindex_localtime on;
    }
}
