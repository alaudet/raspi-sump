#!/bin/bash
set -e

case "$1" in
    purge)
        rm -f /etc/nginx/sites-enabled/raspi-sump
        systemctl reload nginx > /dev/null 2>&1 || true
        systemctl daemon-reload || true
        rm -rf /etc/raspi-sump
        if getent passwd raspisump > /dev/null 2>&1; then
            deluser --system raspisump || true
        fi
        ;;

    remove)
        rm -f /etc/nginx/sites-enabled/raspi-sump
        systemctl reload nginx > /dev/null 2>&1 || true
        systemctl daemon-reload || true
        ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        systemctl daemon-reload || true
        ;;

    *)
        echo "postrm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#
exit 0
