# Raspi-Sump nginx configuration
# HTTP redirects to HTTPS; Flask handles all page requests via Unix socket.

# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name _;

    ssl_certificate     /etc/raspi-sump/ssl/raspi-sump.crt;
    ssl_certificate_key /etc/raspi-sump/ssl/raspi-sump.key;

    # Static assets (CSS, JS) — served directly without hitting Flask
    location /static/ {
        alias /usr/share/raspi-sump/web/static/;
        expires 1h;
    }

    # Charts (PNG files) — served directly from the state directory
    location /charts/ {
        alias /var/lib/raspi-sump/charts/;
        autoindex off;
    }

    # All other requests proxied to the Flask app
    location / {
        proxy_pass http://unix:/run/raspi-sump/flask.sock;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
